{
	"name": "@go-go-scope/persistence-mysql",
	"version": "2.4.0",
	"description": "MySQL/MariaDB persistence adapter for go-go-scope - distributed locks and circuit breaker state",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "pkgroll --clean-dist",
		"lint": "biome check --write src/",
		"test": "vitest run --passWithNoTests",
		"clean": "rm -rf dist",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"mysql",
		"mariadb",
		"persistence",
		"distributed-locks",
		"circuit-breaker",
		"go-go-scope"
	],
	"engines": {
		"node": ">=24.0.0"
	},
	"author": "thelinuxlich",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/thelinuxlich/go-go-scope.git",
		"directory": "packages/persistence-mysql"
	},
	"files": [
		"dist/",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"go-go-scope": "workspace:*"
	},
	"peerDependencies": {
		"mysql2": "^3.17.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@types/node": "^24",
		"mysql2": "^3.18.0",
		"pkgroll": "^2.26.3",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
