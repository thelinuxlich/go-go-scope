{
	"name": "@go-go-scope/adapter-astro",
	"version": "2.7.1",
	"description": "Astro adapter for go-go-scope - Request-scoped structured concurrency for Astro applications",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "pkgroll --clean-dist",
		"test": "vitest run --passWithNoTests",
		"lint": "biome check --write src/",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"keywords": [
		"go-go-scope",
		"astro",
		"structured-concurrency",
		"ssr",
		" islands-architecture"
	],
	"engines": {
		"node": ">=24.0.0"
	},
	"author": "thelinuxlich",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/thelinuxlich/go-go-scope.git",
		"directory": "packages/adapter-astro"
	},
	"files": [
		"dist/",
		"README.md",
		"LICENSE"
	],
	"dependencies": {
		"go-go-scope": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@types/node": "^24",
		"astro": "^4.0.0",
		"pkgroll": "^2.26.3",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"peerDependencies": {
		"astro": "^4.0.0 || ^5.0.0"
	}
}
