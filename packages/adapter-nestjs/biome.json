{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "extends": ["../../packages/go-go-scope/biome.json"],
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  },
  "linter": {
    "rules": {
      "suspicious": {
        "noExplicitAny": "off"
      },
      "complexity": {
        "noStaticOnlyClass": "off"
      }
    }
  }
}
