{
	"name": "@go-go-scope/plugin-worker-profiler",
	"version": "2.9.1",
	"description": "Worker performance profiling plugin for go-go-scope",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "pkgroll --clean-dist --packagejson='dist/index*'",
		"test": "npm run build && vitest run --passWithNoTests",
		"lint": "biome check --write src/",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"keywords": [
		"go-go-scope",
		"plugin",
		"worker",
		"profiling",
		"performance"
	],
	"engines": {
		"node": ">=24.0.0"
	},
	"author": "thelinuxlich",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/thelinuxlich/go-go-scope.git",
		"directory": "packages/plugin-worker-profiler"
	},
	"files": [
		"dist/",
		"README.md",
		"LICENSE"
	],
	"dependencies": {
		"go-go-scope": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"pkgroll": "^2.26.3",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
