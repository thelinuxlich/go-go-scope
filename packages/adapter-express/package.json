{
	"name": "@go-go-scope/adapter-express",
	"version": "2.8.0",
	"description": "Express adapter for go-go-scope - request-scoped structured concurrency",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "pkgroll --clean-dist",
		"lint": "biome check --write src/",
		"test": "vitest run --passWithNoTests",
		"clean": "rm -rf dist",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"express",
		"adapter",
		"go-go-scope",
		"structured-concurrency"
	],
	"engines": {
		"node": ">=24.0.0"
	},
	"author": "thelinuxlich",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/thelinuxlich/go-go-scope.git",
		"directory": "packages/adapter-express"
	},
	"files": [
		"dist/",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"go-go-scope": "workspace:*"
	},
	"peerDependencies": {
		"express": "^5.2.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@types/express": "^5.0.6",
		"@types/node": "^24",
		"express": "^5.2.1",
		"pkgroll": "^2.26.3",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
