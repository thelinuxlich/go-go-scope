{
	"name": "@go-go-scope/persistence-sqlite",
	"version": "2.5.0",
	"description": "SQLite persistence adapter for go-go-scope - distributed locks and circuit breaker state",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "pkgroll --clean-dist",
		"lint": "biome check --write src/",
		"test": "vitest run --passWithNoTests",
		"clean": "rm -rf dist",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"sqlite",
		"persistence",
		"distributed-locks",
		"circuit-breaker",
		"go-go-scope"
	],
	"engines": {
		"node": ">=24.0.0"
	},
	"author": "thelinuxlich",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/thelinuxlich/go-go-scope.git",
		"directory": "packages/persistence-sqlite"
	},
	"files": [
		"dist/",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"go-go-scope": "workspace:*"
	},
	"peerDependencies": {
		"sqlite3": "^5.1.7"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@types/node": "^24",
		"@types/sqlite3": "^5.1.0",
		"pkgroll": "^2.26.3",
		"sqlite3": "^5.1.7",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
