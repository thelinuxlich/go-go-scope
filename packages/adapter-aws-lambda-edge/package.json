{
	"name": "@go-go-scope/adapter-aws-lambda-edge",
	"version": "2.7.1",
	"description": "AWS Lambda@Edge adapter for go-go-scope",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs"
		}
	},
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"files": ["dist"],
	"scripts": {
		"build": "pkgroll --clean-dist",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsc --noEmit",
		"lint": "biome check --write"
	},
	"dependencies": {
		"go-go-scope": "workspace:*"
	},
	"devDependencies": {
		"@types/aws-lambda": "^8.10.131",
		"@types/node": "^22.15.17",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18",
		"pkgroll": "^2.26.3"
	},
	"peerDependencies": {
		"go-go-scope": "^2.6.0"
	}
}
