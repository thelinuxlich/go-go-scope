{
	"name": "@go-go-scope/adapter-solid-start",
	"version": "2.9.0",
	"description": "SolidStart adapter for go-go-scope - Request-scoped structured concurrency for SolidStart applications",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "pkgroll --clean-dist",
		"test": "vitest run --passWithNoTests",
		"lint": "biome check --write src/",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"keywords": [
		"go-go-scope",
		"solid",
		"solidjs",
		"solid-start",
		"structured-concurrency"
	],
	"engines": {
		"node": ">=24.0.0"
	},
	"author": "thelinuxlich",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/thelinuxlich/go-go-scope.git",
		"directory": "packages/adapter-solid-start"
	},
	"files": [
		"dist/",
		"README.md",
		"LICENSE"
	],
	"dependencies": {
		"go-go-scope": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@solidjs/start": "^1.0.0",
		"@types/node": "^24",
		"pkgroll": "^2.26.3",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"peerDependencies": {
		"@solidjs/start": "^1.0.0",
		"@solidjs/router": "^0.13.0"
	}
}
