{
	"name": "@go-go-scope/adapter-remix",
	"version": "2.5.0",
	"description": "Remix adapter for go-go-scope",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "pkgroll",
		"typecheck": "tsc --noEmit",
		"lint": "biome check --fix src",
		"test": "vitest run",
		"test:watch": "vitest",
		"clean": "rm -rf dist"
	},
	"keywords": [
		"structured-concurrency",
		"remix",
		"loader",
		"action",
		"typescript"
	],
	"author": "Your Name",
	"license": "MIT",
	"peerDependencies": {
		"go-go-scope": "^2.4.0",
		"@remix-run/server-runtime": "^2.0.0"
	},
	"devDependencies": {
		"@remix-run/server-runtime": "^2.0.0",
		"@types/node": "^22.13.15",
		"go-go-scope": "workspace:*",
		"pkgroll": "^2.6.1",
		"typescript": "^5.8.3",
		"vitest": "^3.1.1"
	}
}
