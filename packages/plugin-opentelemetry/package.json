{
	"name": "@go-go-scope/plugin-opentelemetry",
	"version": "2.3.1",
	"description": "OpenTelemetry plugin for go-go-scope",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "pkgroll --clean-dist",
		"lint": "biome check --write src/",
		"test": "vitest run",
		"clean": "rm -rf dist",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"go-go-scope",
		"opentelemetry",
		"tracing",
		"plugin"
	],
	"engines": {
		"node": ">=24.0.0"
	},
	"author": "thelinuxlich",
	"license": "MIT",
	"peerDependencies": {
		"go-go-scope": "workspace:*"
	},
	"dependencies": {
		"@opentelemetry/api": "^1.9.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@types/node": "^24",
		"go-go-scope": "workspace:*",
		"pkgroll": "^2.26.3",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
