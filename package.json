{
	"name": "go-go-scope-monorepo",
	"version": "2.3.1",
	"description": "Structured concurrency for TypeScript using Explicit Resource Management",
	"type": "module",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "pnpm -r build",
		"build:core": "pnpm --filter go-go-scope build",
		"build:scheduler": "pnpm --filter @go-go-scope/scheduler build",
		"build:tui": "pnpm --filter @go-go-scope/scheduler-tui build",
		"build:adapters": "pnpm --filter @go-go-scope/adapter-* build",
		"build:persistence": "pnpm --filter @go-go-scope/persistence-* build",
		"typecheck": "pnpm -r typecheck",
		"typecheck:core": "pnpm --filter go-go-scope typecheck",
		"lint": "pnpm -r lint",
		"test": "pnpm -r test",
		"test:core": "pnpm --filter go-go-scope test",
		"test:scheduler": "pnpm --filter @go-go-scope/scheduler test",
		"test:bun:core": "bun test packages/go-go-scope/tests/core.test.ts packages/go-go-scope/tests/concurrency.test.ts packages/go-go-scope/tests/cancellation.test.ts packages/go-go-scope/tests/stream.test.ts packages/go-go-scope/tests/channel-backpressure.test.ts packages/go-go-scope/tests/idempotency.test.ts",
		"test:bun:all": "bun test packages/go-go-scope/tests/*.test.ts packages/persistence-sqlite-bun/src/index.test.ts",
		"clean": "pnpm -r clean",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "pnpm build && changeset publish",
		"publish:all": "pnpm build && pnpm -r publish --access public",
		"publish:core": "pnpm build:core && pnpm --filter go-go-scope publish --access public",
		"publish:scheduler": "pnpm build:scheduler && pnpm --filter @go-go-scope/scheduler publish --access public",
		"publish:tui": "pnpm build:tui && pnpm --filter @go-go-scope/scheduler-tui publish --access public",
		"publish:adapters": "pnpm build:adapters && pnpm --filter '@go-go-scope/adapter-*' publish --access public",
		"publish:persistence": "pnpm build:persistence && pnpm --filter '@go-go-scope/persistence-*' publish --access public",
		"tui": "tsx packages/scheduler-tui/src/tui.ts",
		"tui:redis": "tsx packages/scheduler-tui/src/tui.ts -s redis -u redis://localhost:6379",
		"cli": "tsx packages/scheduler-tui/src/cli.ts"
	},
	"keywords": [
		"structured-concurrency",
		"async",
		"disposable",
		"using",
		"typescript",
		"esm",
		"es2022",
		"scheduler",
		"cron",
		"jobs",
		"monorepo"
	],
	"author": "thelinuxlich",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/thelinuxlich/go-go-scope.git"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@changesets/cli": "^2.29.8",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=8.0.0"
	}
}
